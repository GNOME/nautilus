#: src/nautilus-search-directory-file.c:269
msgid "Search"
msgstr "Wyszukiwanie"

#: data/org.gnome.Nautilus.metainfo.xml.in.in:71
msgid "Selection of Multiple Files"
msgstr "Zaznaczenie wielu plików"

