msgid "_Cancel"
msgstr "_Откажи"

#: extensions/audio-video-properties/totem-properties-view.c:85
#, c-format
msgid "%d hour"
msgid_plural "%d hours"
msgstr[0] "%d час"
msgstr[1] "%d часа"
msgstr[2] "%d часова"
msgstr[3] "један час"

#: extensions/audio-video-properties/totem-properties-view.c:87
#, c-format
msgid "%d minute"
msgid_plural "%d minutes"
msgstr[0] "%d минут"
