#: data/nautilus-autorun-software.desktop.in:2
msgid "Run Software"
msgstr "ເປີດໃຊ້ຊອບແວ"

#: data/org.gnome.Nautilus.desktop.in.in:2
#: data/org.gnome.Nautilus.metainfo.xml.in.in:5 src/nautilus-mime-actions.c:101
#: src/nautilus-portal.c:581 src/resources/ui/nautilus-window.blp:134
msgid "Files"
msgstr "ໄຟລ໌"

#: data/org.gnome.Nautilus.desktop.in.in:3
#: data/org.gnome.Nautilus.metainfo.xml.in.in:6
msgid "Access and organize files"
msgstr "ເຂົ້າເຖິງ ແລະ ຈັດລະບຽບໄຟລ໌"

#. Translators: Search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.Nautilus.desktop.in.in:5
msgid "folder;manager;explore;disk;filesystem;nautilus;"
msgstr "ໂຟນເດີ;ຕົວຈັດການ;ສຳຫຼວດ;ດິດ;ລະບົບໄຟລ໌;nautilus;"

#: data/org.gnome.Nautilus.desktop.in.in:20
msgid "New Window"
msgstr "ໜ້າຕ່າງໃໝ່"

#: data/org.gnome.nautilus.gschema.xml:82
msgid "Always use the location entry, instead of the pathbar"
msgstr "ໃຊ້ຊ່ອງປ້ອນຕຳແໜ່ງສະເໝີ ແທນທີ່ແຖບເສັ້ນທາງ"

#: data/org.gnome.nautilus.gschema.xml:83
msgid ""
"If set to true, Files will always use a textual input entry for the location "
"toolbar, instead of the pathbar."
msgstr "ຫາກຕັ້ງເປັນຄ່າຈິງ, ໂປຣແກຣມໄຟລ໌ຈະໃຊ້ຊ່ອງປ້ອນຂໍ້ຄວາມສຳລັບແຖບເຄື່ອງມືຕຳແໜ່ງສະເໝີ ແທນທີ່ແຖບເສັ້ນທາງ."

#: data/org.gnome.nautilus.gschema.xml:87
msgid "Where to perform recursive search"
msgstr "ບ່ອນທີ່ຈະເຮັດການຄົ້ນຫາແບບລວມທຸກໂຟນເດີຍ່ອຍ"

#: data/org.gnome.nautilus.gschema.xml:88
msgid ""
"Locations in which Files should search subfolders. Available values are "
"“local-only”, “always”, “never”."
msgstr "ຕຳແໜ່ງທີ່ໂປຣແກຣມໄຟລ໌ຄວນຄົ້ນຫາໃນໂຟນເດີຍ່ອຍ. ຄ່າທີ່ມີໃຫ້ຄື “local-only”, “always”, “never”."

#: data/org.gnome.nautilus.gschema.xml:92
msgid "Filter the search dates using either last used or last modified"
msgstr "ກັ່ນຕອງວັນທີຄົ້ນຫາໂດຍໃຊ້ ໃຊ້ຫຼ້າສຸດ ຫຼື ແກ້ໄຂຫຼ້າສຸດ"

#: data/org.gnome.nautilus.gschema.xml:93
msgid "Filter the search dates using either last used or last modified."
msgstr "ກັ່ນຕອງວັນທີຄົ້ນຫາໂດຍໃຊ້ ໃຊ້ຫຼ້າສຸດ ຫຼື ແກ້ໄຂຫຼ້າສຸດ."

#: data/org.gnome.nautilus.gschema.xml:97
msgid "Whether to show a context menu item to delete permanently"
msgstr "ກຳນົດວ່າຈະໃຫ້ສະແດງລາຍການເມນູຄລິກຂວາເພື່ອລຶບຖາວອນຫຼືບໍ່"

#: data/org.gnome.nautilus.gschema.xml:98
msgid ""
"If set to true, Files will show a delete permanently context menu item to "
"bypass the Trash."
msgstr "ຫາກຕັ້ງເປັນຄ່າຈິງ, ໂປຣແກຣມໄຟລ໌ຈະສະແດງລາຍການເມນູລຶບຖາວອນເພື່ອຂ້າມຂັ້ນຕອນການລົງຖັງຂີ້ເຫຍື້ອ."

#: data/org.gnome.nautilus.gschema.xml:102
msgid ""
"Whether to show context menu items to create links from copied or selected "
"files"
msgstr "ກຳນົດວ່າຈະໃຫ້ສະແດງລາຍການເມນູເພື່ອສ້າງລິ້ງຈາກໄຟລ໌ທີ່ຄັດລອກ ຫຼື ເລືອກໄວ້ຫຼືບໍ່"

#: data/org.gnome.nautilus.gschema.xml:103
msgid ""
"If set to true, Files will show context menu items to create links from the "
"copied or selected files."
msgstr "ຫາກຕັ້ງເປັນຄ່າຈິງ, ໂປຣແກຣມໄຟລ໌ຈະສະແດງລາຍການເມນູເພື່ອສ້າງລິ້ງຈາກໄຟລ໌ທີ່ຄັດລອກ ຫຼື ເລືອກໄວ້."

#: data/org.gnome.nautilus.gschema.xml:108
msgid "When to show number of items in a folder"
msgstr "ກຳນົດເວລາທີ່ຈະສະແດງຈຳນວນລາຍການໃນໂຟນເດີ"

#: data/org.gnome.nautilus.gschema.xml:109
msgid ""
"Speed tradeoff for when to show the number of items in a folder. If set to "
"“always” then always show item counts, even if the folder is on a remote "
"server. If set to “local-only” then only show counts for local file systems. "
"If set to “never” then never bother to compute item counts."
msgstr "ການແລກປ່ຽນຄວາມໄວສຳລັບການສະແດງຈຳນວນລາຍການໃນໂຟນເດີ. ຫາກຕັ້ງເປັນ “always” ຈະສະແດງຈຳນວນສະເໝີ ເຖິງວ່າໂຟນເດີຈະຢູ່ເທິງເຊີເວີທາງໄກ. ຫາກຕັ້ງເປັນ “local-only” ຈະສະແດງສະເພາະລະບົບໄຟລ໌ພາຍໃນເຄື່ອງ. ຫາກຕັ້ງເປັນ “never” ຈະບໍ່ມີການຄິດໄລ່ຈຳນວນລາຍການ."

#: data/org.gnome.nautilus.gschema.xml:113
msgid "Type of click used to launch/open files"
msgstr "ຮູບແບບການຄລິກທີ່ໃຊ້ເພື່ອເປີດໄຟລ໌"

#: data/org.gnome.nautilus.gschema.xml:114
msgid ""
"Possible values are “single” to launch files on a single click, or “double” "
"to launch them on a double click."
msgstr "ຄ່າທີ່ເປັນໄປໄດ້ຄື “single” ເພື່ອເປີດໄຟລ໌ດ້ວຍການຄລິກບາດດຽວ, ຫຼື “double” ເພື່ອເປີດດ້ວຍການດັບເບິລຄລິກ."

#: data/org.gnome.nautilus.gschema.xml:118
msgid "Use extra mouse button events in Files"
msgstr "ໃຊ້ປຸ່ມເມົາສ໌ພິເສດໃນໂປຣແກຣມໄຟລ໌"

#: data/org.gnome.nautilus.gschema.xml:119
msgid ""
"For users with mice that have “Forward” and “Back” buttons, this key will "
"determine if any action is taken inside of Files when either is pressed."
msgstr "ສຳລັບຜູ້ໃຊ້ທີ່ມີເມົາສ໌ແບບມີປຸ່ມ “ຖັດໄປ” ແລະ “ກັບຄືນ”, ຄ່ານີ້ຈະກຳນົດວ່າຈະໃຫ້ມີການກະທຳໃດໆໃນໂປຣແກຣມໄຟລ໌ຫຼືບໍ່ເມື່ອມີການກົດປຸ່ມດັ່ງກ່າວ."

#: data/org.gnome.nautilus.gschema.xml:123
msgid "Mouse button to activate the “Forward” command in browser window"
msgstr "ປຸ່ມເມົາສ໌ເພື່ອໃຊ້ຄຳສັ່ງ “ຖັດໄປ” ໃນໜ້າຕ່າງການສຳຫຼວດ"

#: data/org.gnome.nautilus.gschema.xml:124
msgid ""
"For users with mice that have buttons for “Forward” and “Back”, this key "
"will set which button activates the “Forward” command in a browser window. "
"Possible values range between 6 and 14."
msgstr "ສຳລັບຜູ້ໃຊ້ທີ່ມີເມົາສ໌ແບບມີປຸ່ມ “ຖັດໄປ” ແລະ “ກັບຄືນ”, ຄ່ານີ້ຈະຕັ້ງວ່າປຸ່ມໃດຈະໃຊ້ຄຳສັ່ງ “ຖັດໄປ”. ຄ່າທີ່ເປັນໄປໄດ້ແມ່ນລະຫວ່າງ 6 ຫາ 14."

#: data/org.gnome.nautilus.gschema.xml:128
msgid "Mouse button to activate the “Back” command in browser window"
msgstr "ປຸ່ມເມົາສ໌ເພື່ອໃຊ້ຄຳສັ່ງ “ກັບຄືນ” ໃນໜ້າຕ່າງການສຳຫຼວດ"

#: data/org.gnome.nautilus.gschema.xml:129
msgid ""
"For users with mice that have buttons for “Forward” and “Back”, this key "
"will set which button activates the “Back” command in a browser window. "
"Possible values range between 6 and 14."
msgstr "ສຳລັບຜູ້ໃຊ້ທີ່ມີເມົາສ໌ແບບມີປຸ່ມ “ຖັດໄປ” ແລະ “ກັບຄືນ”, ຄ່ານີ້ຈະຕັ້ງວ່າປຸ່ມໃດຈະໃຊ້ຄຳສັ່ງ “ກັບຄືນ”. ຄ່າທີ່ເປັນໄປໄດ້ແມ່ນລະຫວ່າງ 6 ຫາ 14."

#: data/org.gnome.nautilus.gschema.xml:134
msgid "When to show thumbnails of files"
msgstr "ກຳນົດເວລາທີ່ຈະສະແດງຮູບຕົວຢ່າງຂອງໄຟລ໌"

#: data/org.gnome.nautilus.gschema.xml:135
msgid ""
"Speed trade-off for when to show a file as a thumbnail. If set to “always” "
"then always thumbnail, even if the folder is on a remote server. If set to "
"“local-only” then only show thumbnails for local file systems. If set to "
"“never” then never bother to thumbnail files, just use a generic icon. "
"Despite what the name may suggest, this applies to any previewable file type."
msgstr "ການແລກປ່ຽນຄວາມໄວສຳລັບການສະແດງຮູບຕົວຢ່າງ. ຫາກຕັ້ງເປັນ “always” ຈະສະແດງຮູບຕົວຢ່າງສະເໝີ ເຖິງວ່າໄຟລ໌ຈະຢູ່ເທິງເຊີເວີທາງໄກ. ຫາກຕັ້ງເປັນ “local-only” ຈະສະແດງສະເພາະລະບົບໄຟລ໌ພາຍໃນເຄື່ອງ. ຫາກຕັ້ງເປັນ “never” ຈະໃຊ້ພຽງໄອຄອນທົ່ວໄປ. ຄ່ານີ້ໃຊ້ໄດ້ກັບທຸກປະເພດໄຟລ໌ທີ່ສາມາດສະແດງຕົວຢ່າງໄດ້."

#: data/org.gnome.nautilus.gschema.xml:139
msgid "Maximum image size for thumbnailing"
msgstr "ຂະໜາດຮູບສູງສຸດທີ່ຈະສ້າງຮູບຕົວຢ່າງ"

#: data/org.gnome.nautilus.gschema.xml:140
msgid ""
"Images over this size (in megabytes) won’t be thumbnailed. The purpose of "
"this setting is to avoid thumbnailing large images that may take a long time "
"to load or use lots of memory."
msgstr "ຮູບທີ່ມີຂະໜາດເກີນນີ້ (ເປັນເມກາໄບຕ໌) ຈະບໍ່ຖືກສ້າງຮູບຕົວຢ່າງ. ຈຸດປະສົງແມ່ນເພື່ອຫຼີກລ່ຽງການໃຊ້ເວລາໂຫຼດດົນ ຫຼື ໃຊ້ໜ່ວຍຄວາມຈຳຫຼາຍເກີນໄປ."

#: data/org.gnome.nautilus.gschema.xml:147
msgid "Default sort order"
msgstr "ລໍາດັບການລຽງທີ່ເປັນຄ່າເລີ່ມຕົ້ນ"

#: data/org.gnome.nautilus.gschema.xml:148
msgid ""
"The default sort-order for items in the icon view. Possible values are "
"“name”, “size”, “type”, “mtime”, “atime” and “starred”."
msgstr "ລໍາດັບການລຽງເລີ່ມຕົ້ນໃນມຸມມອງໄອຄອນ. ຄ່າທີ່ເປັນໄປໄດ້ແມ່ນ “name”, “size”, “type”, “mtime”, “atime” ແລະ “starred”."

#: data/org.gnome.nautilus.gschema.xml:152
msgid "Reverse sort order in new windows"
msgstr "ລຽງລໍາດັບແບບກັບຄືນໃນໜ້າຕ່າງໃໝ່"

#: data/org.gnome.nautilus.gschema.xml:153
msgid ""
"If true, files in new windows will be sorted in reverse order. I.e., if "
"sorted by name, then instead of sorting the files from “a” to “z”, they will "
"be sorted from “z” to “a”; if sorted by size, instead of being incrementally "
"they will be sorted decrementally."
msgstr "ຫາກຕັ້ງເປັນຄ່າຈິງ, ໄຟລ໌ໃນໜ້າຕ່າງໃໝ່ຈະຖືກລຽງແບບກັບຄືນ. ເຊັ່ນ: ຫາກລຽງຕາມຊື່ ຈະລຽງຈາກ “z” ຫາ “a” ແທນ."

#: data/org.gnome.nautilus.gschema.xml:163
msgid "Default folder viewer"
msgstr "ຕົວເບິ່ງໂຟນເດີເລີ່ມຕົ້ນ"

#: data/org.gnome.nautilus.gschema.xml:164
msgid ""
"When a folder is visited this viewer is used. Possible values are “list-"
"view”, and “icon-view”."
msgstr "ເມື່ອເປີດເບິ່ງໂຟນເດີ ຈະໃຊ້ຕົວເບິ່ງນີ້. ຄ່າທີ່ເປັນໄປໄດ້ຄື “list-view” ແລະ “icon-view”."

#: data/org.gnome.nautilus.gschema.xml:168
msgid "Whether to show hidden files"
msgstr "ກຳນົດວ່າຈະໃຫ້ສະແດງໄຟລ໌ທີ່ຊ່ອນຢູ່ຫຼືບໍ່"

#: data/org.gnome.nautilus.gschema.xml:169
msgid ""
"This key is deprecated and ignored. The “show-hidden” key from "
"“org.gtk.Settings.FileChooser” is now used instead."
msgstr "ຄ່ານີ້ຖືກຍົກເລີກການໃຊ້ງານແລ້ວ. ໃຫ້ໄປໃຊ້ “show-hidden” ໃນ “org.gtk.Settings.FileChooser” ແທນ."

#: data/org.gnome.nautilus.gschema.xml:173
msgid "Whether GTK 4 settings migration happened"
msgstr "ກຳນົດວ່າການຍ້າຍການຕັ້ງຄ່າ GTK 4 ສຳເລັດແລ້ວຫຼືບໍ່"

#: data/org.gnome.nautilus.gschema.xml:174
msgid ""
"Whether settings shared with GtkFileChooser have been migrated from their "
"GTK 3 keys to the GTK 4 ones."
msgstr "ກຳນົດວ່າການຕັ້ງຄ່າທີ່ໃຊ້ຮ່ວມກັບ GtkFileChooser ຖືກຍ້າຍຈາກ GTK 3 ໄປ GTK 4 ແລ້ວຫຼືບໍ່."

#: data/org.gnome.nautilus.gschema.xml:178
msgid ""
"Whether to open the hovered folder after a timeout when drag and drop "
"operation"
msgstr "ກຳນົດວ່າຈະໃຫ້ເປີດໂຟນເດີທີ່ລາກໄປວາງໄວ້ຫຼັງຈາກໝົດເວລາຫຼືບໍ່"

#: data/org.gnome.nautilus.gschema.xml:179
msgid ""
"If this is set to true, when performing a drag and drop operation the "
"hovered folder will open automatically after a timeout."
msgstr "ຫາກຕັ້ງເປັນຄ່າຈິງ, ເມື່ອເຮັດການລາກແລ້ວວາງ ໂຟນເດີທີ່ເມົາສ໌ຄ້າງໄວ້ຈະເປີດອອກໂດຍອັດຕະໂນມັດ."

#: data/org.gnome.nautilus.gschema.xml:183
msgid ""
"Whether to have full text search enabled by default when opening a new "
"window/tab"
msgstr "ກຳນົດວ່າຈະໃຫ້ເປີດການຄົ້ນຫາຂໍ້ຄວາມທັງໝົດເປັນຄ່າເລີ່ມຕົ້ນເມື່ອເປີດໜ້າຕ່າງ/ແທັບໃໝ່ຫຼືບໍ່"

#: data/org.gnome.nautilus.gschema.xml:184
msgid ""
"If set to true, Files will also match the file contents besides the name. "
"This toggles the default active state, which can still be overridden in the "
"search popover"
msgstr "ຫາກຕັ້ງເປັນຄ່າຈິງ, ໂປຣແກຣມໄຟລ໌ຈະຄົ້ນຫາຈາກເນື້ອໃນໄຟລ໌ນຳນອກຈາກຊື່ໄຟລ໌."

#: data/org.gnome.nautilus.gschema.xml:188
msgid "How to display file timestamps in the views"
msgstr "ວິທີສະແດງເວລາຂອງໄຟລ໌ໃນມຸມມອງຕ່າງໆ"

#: data/org.gnome.nautilus.gschema.xml:189
msgid ""
"If set to 'simple', Files will show Today and Yesterday with time, otherwise "
"the exact date without time. If set to 'detailed', it will always show the "
"exact date and time."
msgstr "ຫາກຕັ້ງເປັນ 'simple', ຈະສະແດງເປັນ ມື້ນີ້ ແລະ ມື້ວານນີ້ ພ້ອມເວລາ. ຫາກຕັ້ງເປັນ 'detailed' ຈະສະແດງວັນທີ ແລະ ເວລາທີ່ລະອຽດສະເໝີ."

#: data/org.gnome.nautilus.gschema.xml:196
msgid "Default format for compressing files"
msgstr "ຮູບແບບເລີ່ມຕົ້ນສຳລັບການບີບອັດໄຟລ໌"

#: data/org.gnome.nautilus.gschema.xml:197
msgid "The format that will be selected when compressing files."
msgstr "ຮູບແບບທີ່ຈະຖືກເລືອກເມື່ອມີການບີບອັດໄຟລ໌."

#: data/org.gnome.nautilus.gschema.xml:204
msgid "List of possible captions on icons"
msgstr "ລາຍການຄຳອະທິບາຍທີ່ເປັນໄປໄດ້ໃຕ້ໄອຄອນ"

#: data/org.gnome.nautilus.gschema.xml:205
msgid ""
"A list of captions below an icon in the icon view. The actual number of "
"captions shown depends on the zoom level. Some possible values are: “size”, "
"“type”, “date_modified”, “owner”, “group”, “permissions”, and “mime_type”."
msgstr "ລາຍການຄຳອະທິບາຍໃຕ້ໄອຄອນ. ຄ່າທີ່ເປັນໄປໄດ້ຄື: “size”, “type”, “date_modified”, “owner”, “group”, “permissions”, ແລະ “mime_type”."

#: data/org.gnome.nautilus.gschema.xml:214
msgid "Default icon view zoom level"
msgstr "ລະດັບການຊູມເລີ່ມຕົ້ນຂອງມຸມມອງໄອຄອນ"

#: data/org.gnome.nautilus.gschema.xml:225
msgid "Default list view zoom level"
msgstr "ລະດັບການຊູມເລີ່ມຕົ້ນຂອງມຸມມອງລາຍການ"

#: data/org.gnome.nautilus.gschema.xml:229
